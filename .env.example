# ProcureIQ local env — copy to .env and adjust
DATABASE_URL=postgresql+psycopg://procureiq:procureiq@localhost:5432/procureiq
API_KEY=procureiq-dev-key
API_BASE_URL=http://localhost:8000
# Optional: enables LLM-powered LangGraph routing; without it, deterministic intent router runs
OPENAI_API_KEY=
LOG_LEVEL=INFO
